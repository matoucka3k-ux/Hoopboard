-- ============================================
-- BASKETBALL CLUB MANAGER - SCHEMA SUPABASE
-- ============================================

-- Extension UUID
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- ============================================
-- TABLES
-- ============================================

-- Table clubs
CREATE TABLE clubs (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  nom TEXT NOT NULL,
  president_email TEXT NOT NULL UNIQUE,
  password_hash TEXT NOT NULL,
  logo_url TEXT,
  stripe_customer_id TEXT,
  subscription_status TEXT DEFAULT 'active' CHECK (subscription_status IN ('active', 'suspended', 'cancelled')),
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Table équipes
CREATE TABLE equipes (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  club_id UUID REFERENCES clubs(id) ON DELETE CASCADE NOT NULL,
  nom TEXT NOT NULL,
  categorie TEXT, -- U13, U15, Séniors, etc.
  coach_nom TEXT,
  qr_code TEXT UNIQUE NOT NULL,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Table joueurs
CREATE TABLE joueurs (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  equipe_id UUID REFERENCES equipes(id) ON DELETE CASCADE NOT NULL,
  nom TEXT NOT NULL,
  prenom TEXT NOT NULL,
  numero_maillot INTEGER,
  photo_url TEXT,
  qr_code TEXT UNIQUE NOT NULL,
  niveau_xp INTEGER DEFAULT 0,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Table matchs
CREATE TABLE matchs (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  equipe_id UUID REFERENCES equipes(id) ON DELETE CASCADE NOT NULL,
  adversaire TEXT NOT NULL,
  date_match TIMESTAMPTZ NOT NULL,
  domicile BOOLEAN DEFAULT true,
  score_equipe INTEGER DEFAULT 0,
  score_adversaire INTEGER DEFAULT 0,
  statut TEXT DEFAULT 'a_venir' CHECK (statut IN ('a_venir', 'en_cours', 'termine')),
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- Table actions (pour table de marque temps réel)
CREATE TABLE actions_match (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  match_id UUID REFERENCES matchs(id) ON DELETE CASCADE NOT NULL,
  joueur_id UUID REFERENCES joueurs(id) ON DELETE CASCADE NOT NULL,
  type_action TEXT NOT NULL CHECK (type_action IN (
    'panier_2pts',
    'panier_3pts', 
    'lf_reussi',
    'lf_rate',
    'rebond_off',
    'rebond_def',
    'passe',
    'faute',
    'interception',
    'contre'
  )),
  quart_temps INTEGER CHECK (quart_temps BETWEEN 1 AND 4),
  temps_restant INTEGER, -- en secondes
  created_at TIMESTAMPTZ DEFAULT NOW()
);

-- ============================================
-- INDEX POUR PERFORMANCES
-- ============================================

CREATE INDEX idx_equipes_club ON equipes(club_id);
CREATE INDEX idx_joueurs_equipe ON joueurs(equipe_id);
CREATE INDEX idx_matchs_equipe ON matchs(equipe_id);
CREATE INDEX idx_matchs_date ON matchs(date_match);
CREATE INDEX idx_actions_match_id ON actions_match(match_id);
CREATE INDEX idx_actions_joueur_id ON actions_match(joueur_id);

-- ============================================
-- FONCTION : Calcul stats joueur
-- ============================================

CREATE OR REPLACE FUNCTION calculer_stats_joueur(p_joueur_id UUID)
RETURNS TABLE (
  matchs_joues BIGINT,
  points_totaux BIGINT,
  paniers_2pts BIGINT,
  paniers_3pts BIGINT,
  lf_reussis BIGINT,
  lf_rates BIGINT,
  rebonds_off BIGINT,
  rebonds_def BIGINT,
  rebonds_totaux BIGINT,
  passes BIGINT,
  interceptions BIGINT,
  contres BIGINT,
  fautes BIGINT,
  pourcentage_2pts NUMERIC,
  pourcentage_3pts NUMERIC,
  pourcentage_lf NUMERIC
) AS $$
BEGIN
  RETURN QUERY
  SELECT 
    COUNT(DISTINCT a.match_id) as matchs_joues,
    -- Points
    SUM(CASE WHEN a.type_action = 'panier_2pts' THEN 2 ELSE 0 END) +
    SUM(CASE WHEN a.type_action = 'panier_3pts' THEN 3 ELSE 0 END) +
    SUM(CASE WHEN a.type_action = 'lf_reussi' THEN 1 ELSE 0 END) as points_totaux,
    -- Paniers
    COUNT(CASE WHEN a.type_action = 'panier_2pts' THEN 1 END) as paniers_2pts,
    COUNT(CASE WHEN a.type_action = 'panier_3pts' THEN 1 END) as paniers_3pts,
    -- Lancers francs
    COUNT(CASE WHEN a.type_action = 'lf_reussi' THEN 1 END) as lf_reussis,
    COUNT(CASE WHEN a.type_action = 'lf_rate' THEN 1 END) as lf_rates,
    -- Rebonds
    COUNT(CASE WHEN a.type_action = 'rebond_off' THEN 1 END) as rebonds_off,
    COUNT(CASE WHEN a.type_action = 'rebond_def' THEN 1 END) as rebonds_def,
    COUNT(CASE WHEN a.type_action IN ('rebond_off', 'rebond_def') THEN 1 END) as rebonds_totaux,
    -- Autres
    COUNT(CASE WHEN a.type_action = 'passe' THEN 1 END) as passes,
    COUNT(CASE WHEN a.type_action = 'interception' THEN 1 END) as interceptions,
    COUNT(CASE WHEN a.type_action = 'contre' THEN 1 END) as contres,
    COUNT(CASE WHEN a.type_action = 'faute' THEN 1 END) as fautes,
    -- Pourcentages (éviter division par zéro)
    CASE WHEN COUNT(CASE WHEN a.type_action = 'panier_2pts' THEN 1 END) > 0 
      THEN ROUND((COUNT(CASE WHEN a.type_action = 'panier_2pts' THEN 1 END)::NUMERIC / COUNT(CASE WHEN a.type_action = 'panier_2pts' THEN 1 END)::NUMERIC * 100), 1)
      ELSE 0 
    END as pourcentage_2pts,
    CASE WHEN COUNT(CASE WHEN a.type_action = 'panier_3pts' THEN 1 END) > 0 
      THEN ROUND((COUNT(CASE WHEN a.type_action = 'panier_3pts' THEN 1 END)::NUMERIC / COUNT(CASE WHEN a.type_action = 'panier_3pts' THEN 1 END)::NUMERIC * 100), 1)
      ELSE 0 
    END as pourcentage_3pts,
    CASE WHEN (COUNT(CASE WHEN a.type_action = 'lf_reussi' THEN 1 END) + COUNT(CASE WHEN a.type_action = 'lf_rate' THEN 1 END)) > 0
      THEN ROUND((COUNT(CASE WHEN a.type_action = 'lf_reussi' THEN 1 END)::NUMERIC / (COUNT(CASE WHEN a.type_action = 'lf_reussi' THEN 1 END) + COUNT(CASE WHEN a.type_action = 'lf_rate' THEN 1 END))::NUMERIC * 100), 1)
      ELSE 0 
    END as pourcentage_lf
  FROM actions_match a
  WHERE a.joueur_id = p_joueur_id;
END;
$$ LANGUAGE plpgsql;

-- ============================================
-- FONCTION : Mise à jour score match en temps réel
-- ============================================

CREATE OR REPLACE FUNCTION mettre_a_jour_score_match()
RETURNS TRIGGER AS $$
BEGIN
  UPDATE matchs
  SET score_equipe = (
    SELECT 
      COALESCE(SUM(CASE 
        WHEN a.type_action = 'panier_2pts' THEN 2
        WHEN a.type_action = 'panier_3pts' THEN 3
        WHEN a.type_action = 'lf_reussi' THEN 1
        ELSE 0
      END), 0)
    FROM actions_match a
    WHERE a.match_id = NEW.match_id
  ),
  updated_at = NOW()
  WHERE id = NEW.match_id;
  
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Trigger pour mise à jour auto du score
CREATE TRIGGER trigger_update_score
AFTER INSERT OR DELETE ON actions_match
FOR EACH ROW
EXECUTE FUNCTION mettre_a_jour_score_match();

-- ============================================
-- FONCTION : Calcul niveau joueur (XP)
-- ============================================

CREATE OR REPLACE FUNCTION calculer_niveau_joueur(p_xp INTEGER)
RETURNS TEXT AS $$
BEGIN
  CASE 
    WHEN p_xp < 100 THEN RETURN 'Bronze';
    WHEN p_xp < 300 THEN RETURN 'Argent';
    WHEN p_xp < 600 THEN RETURN 'Or';
    ELSE RETURN 'Diamant';
  END CASE;
END;
$$ LANGUAGE plpgsql;

-- ============================================
-- FONCTION : Mise à jour auto XP joueur
-- ============================================

CREATE OR REPLACE FUNCTION mettre_a_jour_xp_joueur()
RETURNS TRIGGER AS $$
BEGIN
  UPDATE joueurs
  SET niveau_xp = (
    SELECT 
      COALESCE(SUM(CASE 
        WHEN a.type_action = 'panier_2pts' THEN 2
        WHEN a.type_action = 'panier_3pts' THEN 3
        WHEN a.type_action = 'lf_reussi' THEN 1
        WHEN a.type_action = 'passe' THEN 2
        WHEN a.type_action = 'rebond_off' THEN 1
        WHEN a.type_action = 'rebond_def' THEN 1
        WHEN a.type_action = 'interception' THEN 3
        WHEN a.type_action = 'contre' THEN 3
        ELSE 0
      END), 0)
    FROM actions_match a
    WHERE a.joueur_id = NEW.joueur_id
  ),
  updated_at = NOW()
  WHERE id = NEW.joueur_id;
  
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Trigger pour mise à jour auto XP
CREATE TRIGGER trigger_update_xp
AFTER INSERT OR DELETE ON actions_match
FOR EACH ROW
EXECUTE FUNCTION mettre_a_jour_xp_joueur();

